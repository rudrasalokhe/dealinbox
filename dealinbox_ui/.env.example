# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/dealinbox?retryWrites=true&w=majority

# Flask secret key - use a long random string in production
SECRET_KEY=change-this-to-a-long-random-string

# Database name
DB_NAME=dealinbox

# Set to False in production
DEBUG=False

# UPI payment details (for manual UPI fallback)
UPI_ID=yourname@upi
UPI_NAME=YourName

# Razorpay (get from razorpay.com/dashboard -> Settings -> API Keys)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
